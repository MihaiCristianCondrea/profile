{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "strict": false,
    "noImplicitAny": false,
    "noEmitOnError": true,
    "rootDir": "assets/ts",
    "outDir": "assets/js",
    "allowJs": false,
    "skipLibCheck": true
  },
  "include": [
    "assets/ts/**/*.ts"
  ]
}
